# PathBrain configuration (copy to .env and edit)

# --- Storage ---
PATHBRAIN_DATABASE_URL=sqlite:///./data/pathbrain.db

# --- Server ---
PATHBRAIN_HOST=0.0.0.0
PATHBRAIN_PORT=8000
PATHBRAIN_LOG_LEVEL=INFO

# --- Config discovery provider: "opnsense" or "mock" ---
PATHBRAIN_CONFIG_PROVIDER=mock

# --- OPNsense API (used when PATHBRAIN_CONFIG_PROVIDER=opnsense) ---
PATHBRAIN_OPNSENSE_URL=https://192.168.1.1
PATHBRAIN_OPNSENSE_API_KEY=
PATHBRAIN_OPNSENSE_API_SECRET=
# Set to true only if your firewall presents a trusted certificate
PATHBRAIN_OPNSENSE_VERIFY_TLS=false
