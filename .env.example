# PathBrain configuration (copy to .env and edit)

# --- Storage ---
PATHBRAIN_DATABASE_URL=sqlite:///./data/pathbrain.db
# Browser-engine artifacts (screenshots, HAR files)
PATHBRAIN_ARTIFACT_DIR=./data/artifacts

# --- Server ---
PATHBRAIN_HOST=0.0.0.0
PATHBRAIN_PORT=8000
PATHBRAIN_LOG_LEVEL=INFO
# Local timezone for the experiment engine's window hours (and nicer logs).
# e.g. America/New_York. Defaults to UTC.
TZ=UTC

# --- Config discovery provider: "opnsense" or "mock" ---
PATHBRAIN_CONFIG_PROVIDER=mock

# --- OPNsense API (used when PATHBRAIN_CONFIG_PROVIDER=opnsense) ---
# The API user needs traffic-shaper read access (privilege "Firewall: Shaper").
PATHBRAIN_OPNSENSE_URL=https://192.168.1.1
PATHBRAIN_OPNSENSE_API_KEY=
PATHBRAIN_OPNSENSE_API_SECRET=
# Set to true only if your firewall presents a trusted certificate
PATHBRAIN_OPNSENSE_VERIFY_TLS=false

# --- One-click self-update via Watchtower HTTP API ---
# When both are set, the "Update available" chip gains an "Update now" button that POSTs to
# {URL}/v1/update with the Bearer token, telling Watchtower to pull the newer image and recreate
# this container. Run Watchtower with --http-api-update and WATCHTOWER_HTTP_API_TOKEN=<token>.
# Leave the URL blank to disable (the chip stays a link to the GitHub compare).
PATHBRAIN_WATCHTOWER_URL=http://192.168.2.6:8998
PATHBRAIN_WATCHTOWER_TOKEN=
